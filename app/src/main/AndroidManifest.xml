<?xml version="1.0" encoding="utf-8"?>
<!--
  FCL 插件 AndroidManifest.xml

  FCL 启动器扫描已安装应用的此 meta-data 来识别渲染器:
    fclPlugin = true     -> FCL 插件
    renderer  = "Name:libGL:libEGL"  -> 渲染器标识
    boatEnv / pojavEnv  -> FCL / Pojav 启动器环境变量
    minMCVer / maxMCVer  -> MC 版本限制

  参考: MobileGlues-plugin/app/src/main/AndroidManifest.xml
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- FCL 需要的权限 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="@string/app_name"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.NoDisplay">

        <!-- 空 Activity: FCL 只需识别 APK, 不需要 UI -->
        <activity
            android:name="com.mio.plugin.renderer.vmcr.VMCRPluginActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FCL 插件标记 -->
        <meta-data
            android:name="fclPlugin"
            android:value="true" />

        <meta-data
            android:name="des"
            android:value="@string/description" />

        <!-- 渲染器标识: "Name:libGL:libEGL" 格式
             FCL 加载 lib/ 目录下的 libGL.so 和 libEGL.so -->
        <meta-data
            android:name="renderer"
            android:value="VMCR:libGL.so:libEGL.so" />

        <!-- 兼容 Boat 启动器 -->
        <meta-data
            android:name="boatEnv"
            android:value="LIBGL_ES=3:POJAV_RENDERER=opengles3:POJAVEXEC_EGL=libEGL.so" />

        <!-- 兼容 Pojav 启动器 -->
        <meta-data
            android:name="pojavEnv"
            android:value="LIBGL_ES=3:POJAV_RENDERER=opengles3:POJAVEXEC_EGL=libEGL.so" />

        <!-- 支持的 MC 版本: 1.7.10 起 (覆盖 GT: New Horizons 主流老版本)
             1.7.10 用 LWJGL3 (Pojav/FCL 实现), OpenGL 调用经 libGL.so 转发.
             1.16.5+ / 1.17 / 1.18 / 1.19 / 1.20 / 1.21+ 均支持.
             注: 1.7.10 用 Forge 而非 Fabric, JNI Mixin 拦截仅在 1.16.5+ 生效;
                  1.7.10 仅走 GLES forwarding 路径, 无 chunk mesh 截取. -->
        <meta-data
            android:name="minMCVer"
            android:value="1.7.10" />
        <!-- 不设 maxMCVer, 留空支持所有后续版本 -->
    </application>

</manifest>
