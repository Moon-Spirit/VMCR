<?xml version="1.0" encoding="utf-8"?>
<!--
  VMCR — FCL 渲染器插件 (AndroidManifest)

  严格按官方模板 https://github.com/ShirosakiMio/FCLRendererPlugin 的格式:
  - namespace = "com.mio.plugin.renderer" (基础)
  - applicationIdSuffix = ".vmcr" (标识我们的插件)
  - MainActivity 相对 namespace 解析

  FCL 扫描 com.mio.plugin.renderer.* 命名的应用, 读 meta-data,
  提取 lib/<abi>/libGL.so 等到临时目录, dlopen 加载.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="@string/app_name"
        android:allowBackup="true"
        android:extractNativeLibs="true"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.NoDisplay">

        <!-- 占位 Activity: FCL 扫描 LAUNCHER 分类发现插件 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="fclPlugin"
            android:value="true" />

        <meta-data
            android:name="des"
            android:value="@string/description" />

        <!-- 渲染器标识: 名称:libGL:libEGL -->
        <meta-data
            android:name="renderer"
            android:value="VMCR:libGL.so:libEGL.so" />

        <!-- 兼容 Boat 启动器 -->
        <meta-data
            android:name="boatEnv"
            android:value="LIBGL_ES=3:POJAV_RENDERER=opengles3:POJAVEXEC_EGL=libEGL.so" />

        <!-- 兼容 Pojav 启动器 -->
        <meta-data
            android:name="pojavEnv"
            android:value="LIBGL_ES=3:POJAV_RENDERER=opengles3:POJAVEXEC_EGL=libEGL.so" />

        <!-- 最低支持 MC 版本: 1.7.10 (覆盖 GTNH 主流老版本) -->
        <meta-data
            android:name="minMCVer"
            android:value="1.7.10" />
    </application>

</manifest>
